# Copy to .env and fill in. .env is gitignored — never commit secrets.

# Foundry project (Microsoft Foundry Agents API + OpenAI-compatible endpoints)
FOUNDRY_PROJECT_ENDPOINT=https://llmops-project-resource.services.ai.azure.com/api/projects/llmops-project

# --- The models in the headline AST comparison (deployment names) -------------
# teacher    = frontier quality bar (GPT-5.4).
# finetuned  = distilled student = Qwen3-32B after Foundry managed SFT + deploy.
# baseline   = OPTIONAL "before" proxy. Base Qwen3-32B inference is NOT available
#              on Foundry (fine-tune-only), so use an off-task / format-primer
#              fine-tune as a near-base proxy, or leave blank (headline =
#              teacher vs distilled).
TEACHER_MODEL=gpt-5.4
STUDENT_FINETUNED_DEPLOYMENT=
BASELINE_DEPLOYMENT=

# Cheap reference + (optional) judge. AST scoring is objective and needs no judge.
STUDENT_MODEL=gpt-4.1-mini
JUDGE_MODEL=gpt-5.4

# --- Fine-tuning base model (dev3: small + continuous fine-tuning) -------------
# gpt-4.1-nano is the smallest Azure OpenAI model that supports CONTINUOUS
# fine-tuning (a fine-tuned model can be the base of the next job) — unlike the
# serverless Qwen/Phi/OSS models. Fallback: gpt-4o-mini.
BASE_FINETUNE_MODEL=gpt-4.1-nano
# gpt-4.1-nano requires "Global" (its capability is globalFineTune; "Standard"
# is rejected). Leave empty only for models that support Standard fine-tuning.
FINETUNE_TRAINING_TYPE=GlobalStandard
# Foundry resource for auto-deploying fine-tuned models via `az` (enables the
# loop's DEPLOY stage to run unattended). Find with: az resource list
#   --resource-type Microsoft.CognitiveServices/accounts
FOUNDRY_AOAI_ACCOUNT=TuneSEfoundry
FOUNDRY_RESOURCE_GROUP=demo-rg

# --- Tool-calling data source -------------------------------------------------
# sample = bundled offline BFCL-style set (runs anywhere); hf = pull at scale;
# or an absolute path to a directory of BFCL-format JSONL files.
TOOLCALLING_SOURCE=sample

# --- Foundry Tracing -> Microsoft Fabric (production trace push) --------------
FABRIC_WORKSPACE_ID=
FABRIC_LAKEHOUSE=

# Web Search (WebIQ) localization for the web_search tool — optional.
WEBSEARCH_COUNTRY=US
WEBSEARCH_CITY=New York
WEBSEARCH_REGION=NY
